# Add your own Stripe secret key here
STRIPE_API_KEY=

# --- Stripe webhooks (two endpoints, two secrets) ---
#
# 1) Medusa payment provider webhook — required for payment_intent.* when using Connect DIRECT charges.
#    URL: https://<MEDUSA_HOST>/hooks/payment/stripe-connect
#    In Stripe Dashboard → Webhooks → Add endpoint → enable "Listen to events on Connected accounts"
#    (wording may vary). Subscribe at least: payment_intent.succeeded, payment_intent.amount_capturable_updated,
#    payment_intent.payment_failed (and optionally charge.refunded).
# STRIPE_WEBHOOK_SECRET=whsec_...
#
# 2) Custom route for Connect account onboarding sync (account.updated):
#    URL: https://<MEDUSA_HOST>/webhooks/stripe-connect
# STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...
#
# Stripe cannot POST to localhost; use ngrok (or similar) for local testing.

# Stripe Connect is always enabled (Express + direct charges on connected account).
# Ensure you complete Stripe onboarding in the admin before attempting checkout.
# Refund application fee when refunding (platform commission returned to connected account when true)
# REFUND_APPLICATION_FEE=false

# Sentry configuration
# Find your DSN in Sentry: Settings → Projects → <your project> → Client Keys
SENTRY_DSN=
# Optional: only required if you plan to enable Sentry webhooks
# SENTRY_API_TOKEN=
