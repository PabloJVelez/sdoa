DB_NAME=sdoa
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/${DB_NAME}
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/${DB_NAME}

STORE_CORS=http://localhost:8000,https://docs.medusajs.com
ADMIN_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
AUTH_CORS=http://localhost:7000,http://localhost:7001,https://docs.medusajs.com
REDIS_URL=redis://localhost:6379
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

ADMIN_BACKEND_URL=http://localhost:9000

# Add your own Stripe secret key here
STRIPE_API_KEY=

# Stripe Connect (optional). When USE_STRIPE_CONNECT=false or unset, provider uses standard Stripe (no Connect).
USE_STRIPE_CONNECT=false
# Required when USE_STRIPE_CONNECT=true. Stripe connected account id (acct_xxx).
STRIPE_CONNECTED_ACCOUNT_ID=
# Platform application fee percentage (e.g. 5 for 5%). Default: 5
PLATFORM_FEE_PERCENT=5
# When true, refunds include application fee refund. Default: false (platform keeps fee).
REFUND_APPLICATION_FEE=false
# Webhook signing secret for Stripe Connect events (optional but recommended).
STRIPE_WEBHOOK_SECRET=
# Optional: pass Stripe processing fee to connected account (gross-up). Default: false
PASS_STRIPE_FEE_TO_CHEF=false
STRIPE_FEE_PERCENT=2.9
STRIPE_FEE_FLAT_CENTS=30

# Sentry configuration
# Find your DSN in Sentry: Settings → Projects → <your project> → Client Keys
SENTRY_DSN=
# Optional: only required if you plan to enable Sentry webhooks
# SENTRY_API_TOKEN=
